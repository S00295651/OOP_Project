<Window x:Class="OOP_Project.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Login" Height="520" Width="420"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border Background="#1B2838" BorderBrush="#2A475E" BorderThickness="1" CornerRadius="0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Rectangle Grid.Row="0" Fill="#171A21"/>
            <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0,0,0">
                <materialDesign:PackIcon Kind="Gamepad" Foreground="#66C0F4"
                                         Width="20" Height="20" VerticalAlignment="Center"/>
                <TextBlock Text="GAME LIBRARY" Foreground="White" FontSize="14"
                           FontWeight="Bold" Margin="10,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
            <Button x:Name="btnClose" Click="btnClose_Click"
                    VerticalAlignment="Stretch" HorizontalAlignment="Right"
                    Width="45" Background="Transparent" BorderBrush="Transparent" Grid.Row="0">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Content" Value="✕"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="FontSize" Value="16"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#C93129"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <!-- Main Content -->
            <StackPanel Grid.Row="1" Margin="40,20,40,30" VerticalAlignment="Center">

                <!-- Logo / Title -->
                <materialDesign:PackIcon Kind="AccountCircle" Foreground="#66C0F4"
                                         Width="56" Height="56" HorizontalAlignment="Center"/>
                <TextBlock x:Name="txtTitle" Text="Sign In" Foreground="White"
                           FontSize="24" FontWeight="Bold"
                           HorizontalAlignment="Center" Margin="0,12,0,4"/>
                <TextBlock x:Name="txtSubtitle" Text="Access your game library anywhere"
                           Foreground="#C7D5E0" FontSize="13"
                           HorizontalAlignment="Center" Margin="0,0,0,28"/>

                <!-- Email -->
                <TextBlock Text="Email" Foreground="#4A6880" FontSize="11" Margin="0,0,0,6"/>
                <Border Background="#16202D" BorderBrush="#2A475E" BorderThickness="1"
                        CornerRadius="3" Padding="12,10" Margin="0,0,0,16">
                    <TextBox x:Name="txtEmail" Background="Transparent" BorderBrush="Transparent"
                             Foreground="White" FontSize="14" CaretBrush="White"
                             KeyDown="Input_KeyDown"/>
                </Border>

                <!-- Password -->
                <TextBlock Text="Password" Foreground="#4A6880" FontSize="11" Margin="0,0,0,6"/>
                <Border Background="#16202D" BorderBrush="#2A475E" BorderThickness="1"
                        CornerRadius="3" Padding="12,10" Margin="0,0,0,6">
                    <PasswordBox x:Name="txtPassword" Background="Transparent" BorderBrush="Transparent"
                                 Foreground="White" FontSize="14" CaretBrush="White"
                                 KeyDown="Input_KeyDown"/>
                </Border>

                <!-- Error Message -->
                <TextBlock x:Name="txtError" Foreground="#C93129" FontSize="12"
                           TextWrapping="Wrap" Margin="0,0,0,16" Visibility="Collapsed"/>

                <!-- Loading Indicator -->
                <StackPanel x:Name="loadingPanel" Orientation="Horizontal"
                            HorizontalAlignment="Center" Margin="0,0,0,10" Visibility="Collapsed">
                    <materialDesign:PackIcon Kind="Loading" Foreground="#66C0F4"
                                             Width="18" Height="18" VerticalAlignment="Center">
                        <materialDesign:PackIcon.RenderTransform>
                            <RotateTransform x:Name="spinnerRotate" CenterX="9" CenterY="9"/>
                        </materialDesign:PackIcon.RenderTransform>
                        <materialDesign:PackIcon.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation Storyboard.TargetName="spinnerRotate"
                                                         Storyboard.TargetProperty="Angle"
                                                         From="0" To="360" Duration="0:0:1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </materialDesign:PackIcon.Triggers>
                    </materialDesign:PackIcon>
                    <TextBlock x:Name="txtLoading" Text="Signing in..." Foreground="#C7D5E0"
                               FontSize="13" Margin="8,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Primary Action Button -->
                <Button x:Name="btnAction" Content="Sign In" Click="btnAction_Click"
                        Height="40" FontSize="14" FontWeight="Bold"
                        Background="#1A9FFF" Foreground="White" BorderBrush="Transparent"
                        Margin="0,0,0,14" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="3">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#0F7ACC"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Toggle Login / Register -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock x:Name="txtToggleLabel" Text="Don't have an account? "
                               Foreground="#C7D5E0" FontSize="13"/>
                    <TextBlock x:Name="txtToggleLink" Text="Register"
                               Foreground="#66C0F4" FontSize="13" Cursor="Hand"
                               MouseLeftButtonDown="ToggleMode_Click">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="TextDecorations" Value="Underline"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

            </StackPanel>
        </Grid>
    </Border>
</Window>
